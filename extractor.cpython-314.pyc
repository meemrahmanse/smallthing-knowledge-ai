# -*- coding: utf-8 -*-
"""Text chunking module."""

import re
from backend.config import config


class TableAwareChunker:
    """Chunk text while preserving table structure."""

    def __init__(self, chunk_size: int = 2500, overlap: int = 500):
        self.chunk_size = chunk_size
        self.overlap = overlap

    def chunk(self, text: str) -> list[str]:
        """Split text into chunks."""
        text = text.strip()
        lines = text.split('\n')
        chunks = []
        current_section_lines = []
        current_location = ""
        in_fix_section = False

        section_patterns = [
            r'^PARTE\s+\d+',
            r'^---\s*PAGINA',
            r'^\d+\.\s+[A-Z]',
            r'^LOCATION:\s*ROOM',
        ]

        def is_section_title(line: str) -> bool:
            l = line.strip().upper()
            for p in section_patterns:
                if re.match(p, l):
                    return True
            return False

        def is_env_entry(line: str) -> bool:
            stripped = line.strip()
            if stripped.startswith(('├в', 'тЧП', 'тАв', '-', '*', 'тЦк')):
                return False
            if re.search(r'(RIMUOVERE|CONTROLLARE|ASSICURARSI|AGGIUNGERE|SU\s+ENV)', stripped.upper()):
                return False
            if in_fix_section:
                return False
            stripped_upper = stripped.upper()
            for p in ['ENV', 'NPC', 'BKGNPC']:
                if re.match(rf'^{p}[\s_\-]*\d+', stripped_upper):
                    return True
            return False

        def flush_section():
            nonlocal current_section_lines
            if current_section_lines:
                joined = '\n'.join(current_section_lines).strip()
                if len(joined) > 20:
                    if len(joined) > 3000:
                        for i in range(0, len(joined), 3000):
                            piece = joined[i:i+3000].strip()
                            if piece:
                                chunks.append(piece)
                    else:
                        chunks.append(joined)
                current_section_lines = []

        for line in lines:
            stripped = line.strip()
            if not stripped:
                current_section_lines.append(line)
                continue

            loc_match = re.search(r'LOCATION:\s*(ROOM_?\d+\w*)', stripped.upper())
            if loc_match:
                current_location = loc_match.group(1)

            if 'LISTA DEI FIX' in stripped.upper() or 'FIX E DELLE RIMOZIONI' in stripped.upper():
                in_fix_section = True

            if re.match(r'^PARTE\s+\d+', stripped.upper()) and in_fix_section:
                in_fix_section = False

            if is_section_title(stripped) and not in_fix_section:
                flush_section()
                current_section_lines = [line]
            elif is_env_entry(stripped):
                flush_section()
                current_section_lines = []
                if current_location:
                    current_section_lines.append(f"LOCATION: {current_location}")
                current_section_lines.append(line)
            else:
                current_section_lines.append(line)

        flush_section()
        return [c.strip() for c in chunks if c.strip() and len(c.strip()) > 20]

    def _split_by_location(self, text: str) -> list[str]:
        """Split by location marker."""
        sections = []
        current_section = []

        lines = text.split('\n')

        for line in lines:
            stripped = line.strip()

            if stripped.startswith('- Location:') or stripped.startswith('Location:'):
                if current_section:
                    sections.append('\n'.join(current_section))
                current_section = [line]
            else:
                current_section.append(line)

        if current_section:
            sections.append('\n'.join(current_section))

        return sections

    def _chunk_large_section(self, section: str) -> list[str]:
        """Chunk large sections."""
        lines = section.split('\n')
        chunks = []
        current_chunk = []
        current_size = 0

        header_lines = []
        for line in lines:
            if line.strip().startswith('- Location:') or line.strip().startswith('Location:'):
                header_lines.append(line)
            elif 'ID' in line.upper() and 'NOME' in line.upper():
                header_lines.append(line)
            elif header_lines:
                break

        header = '\n'.join(header_lines)
        header_size = len(header)

        for line in lines:
            if line in header_lines:
                continue

            line_size = len(line) + 1

            if current_size + line_size > self.chunk_size - header_size - 100:
                if current_chunk:
                    chunk_text = header + '\n\n' + '\n'.join(current_chunk)
                    chunks.append(chunk_text)
                current_chunk = [line]
                current_size = line_size
            else:
                current_chunk.append(line)
                current_size += line_size

        if current_chunk:
            chunk_text = header + '\n\n' + '\n'.join(current_chunk)
            chunks.append(chunk_text)

        return chunks


chunker = TableAwareChunker(config.chunk_size, config.chunk_overlap)
